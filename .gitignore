# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.ccls-cache/
compile_commands.json

# ---------------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Local overrides (never commit user-specific overrides)
# ---------------------------------------------------------------------------
.env
.env.local
*.local

# ---------------------------------------------------------------------------
# Local-only development aids (kept on disk but not shipped to GitHub)
# ---------------------------------------------------------------------------
# Headless regression tests — useful during development, skipped in the
# public build. CMake guards the test targets so a fresh clone still
# configures cleanly without this directory present.
tests/
.codex
.claude/
PROJECT_MEMORY.md
SPACE_STATIONS_PLAN.md
record_demo.sh
