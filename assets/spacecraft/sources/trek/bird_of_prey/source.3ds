<!DOCTYPE html><html lang="EN"><head>
			<link rel="icon" type="image/png" href="https://trekmeshes.eu/images/favicon.png">
			<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
		    <meta name="description" content="Collecting high quality Star Trek 3D objects and meshes for free download. Many formats like Blender, Poser, 3DS, MAX, Lightwave LWO and Wavefront OBJ." />

			<meta name="viewport" content="width=device-width, initial-scale=1">
			<style>
			body {
				background-color: black;
			}
			.content {
			font-family: "Verdana", "Sans-serif";
			}
			.logo {
				text-align: center;
			}
			h1 {
				font-weight: bold;
				font-size: medium;
			}
			h2 {
				font-size: medium;
				font-weight: bold;
			}
			a:link {
				font-weight: bold;
				font-size: small;
				text-decoration: underline;
				color: black;				
			}
			a:visited {
				font-weight: bold;
				font-size: small;
				text-decoration: underline;
				color: black;				
			}
			a:hover {
				font-weight: bold;
				font-size: small;
				text-decoration: underline;
				color: #FFC900;				
			}
			a:active {
				font-weight: bold;
				font-size: small;
				text-decoration: underline;
				color: #b61513;				
			}
			.hasTooltip span {
			    display: none;
			    color: #000;
			    text-decoration: none;
			    padding: 3px;
			}
			.hasTooltip:hover span {
			    display: block;
			    position: absolute;
			    background-color: #FFF;
			    border: 1px solid #CCC;
			    margin: 2px 10px;
			}
			.inputfields {
				text-align: center;
				font-family: "Verdana", "Sans-serif";
				font-size: medium;
				width: 98%;
			}
			.textinput {
				font-family: "Verdana", "Sans-serif";
				font-size: medium;
			}
			
			input:required:invalid, input:focus:invalid {
				background-color: #fdedec;
			}
			
			input:required:valid {
				background-color: #eafaf1;
			}
			
			table.centered {
				margin-left: auto;
				margin-right: auto;
			}

			table.defaultTable {
			  border: 2px solid #002d73;
			  background-color: #bdd6fc;
			  width: 100%;
			  text-align: center;
			  border-collapse: collapse;	
			}

			table.defaultTable td, table.defaultTable th {
			  padding: 1px 2px;
			}
			table.defaultTable tbody td {
			  font-size: medium;
			  word-break: normal;			  
			}
			table.defaultTable tbody tr:nth-child(even) {
			  background: #95bdfc;
			}
			table.defaultTable thead {
			  background: #002d73;
			  
			}
			table.defaultTable thead th {
			  font-weight: bold;
			  color: #FFFFFF;
			  text-align: center;
			  border-left: 2px solid #002d73;  
			}		

			table.minWidth {
				width: auto;
			}

			table.rlAlign tbody td:nth-child(even) {
				text-align: left;
			}
			table.rlAlign tbody td:nth-child(odd) {
				text-align: right;
			}	
			table.padded td {
				padding: 5px;
			}

			div.sidebyside {
				display: table-cell;
				padding: 15px;
			}
			div.devider {
				display: table-cell;
			}
			div.centered {
				margin-left: auto;
				margin-right: auto;
			}

			div.tableHeader {
				display: inline-block;
				background: #002d73;					
				font-weight: bold;
				color: #FFFFFF;
				text-align: center;
				border-left: 2px solid #002d73; 
				width: 100%; 
			}	
			div.meshNP {
				display: none;
			}	
			
			@media only screen and (max-width: 900px) {
				div.sidebyside {
				  display: inline-block;
				  padding: 0px;
				}
				div.devider {
					display: none;
				}
				table.meshTable {
					display: none;
				}
				div.meshNP {
					display: block;
				}
			}
			
		</style><title>Mesh and 3D object download</title></head>
			<body><div class="content" style="background: #8F8F8F; text-align: center;"><DIV STYLE="width: 100%; text-align: left;">
				<DIV STYLE="width:200px; display: inline-block;">
					<IMG SRC="https://trekmeshes.eu/images/logo.png" ALT="STMC Logo" />
				</DIV>
				<DIV STYLE="width: calc(100% - 225px); display: inline-block;text-align: center; min-width: 450px;">
					<DIV STYLE="text-align: center; max-width: 95vw;">
						<B STYLE="font-family: Garamond, serif; font-size: xx-large; color: white;">STMC</B><BR/>
						<U><I>The Star Trek Meshes and 3D objects collection</I></U>
						<BR/>&nbsp;
					</DIV>
					<BR/>
					<DIV STYLE="text-align: left; width: 90%; max-width: 90vw; background: #515151; border: 5px solid black; padding-left: 10px; vertical-align: middle;">			<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/welcome'>News</A> | 			<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/download'>Downloads</A> | 			<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/forum'>Forums</A> | 			<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/about'>About</A> | 			<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/contact'>Contact</A> | 			<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/upload'>Upload/share new mesh</A>				<SPAN ID='logOptions'> | 				<A STYLE='text-decoration: none; color: white;' onMouseOver='this.style.color="#FFC900"' onMouseOut='this.style.color="white"' HREF='https://trekmeshes.eu/forum/login'>Log in or register</A>
						</SPAN>
					</DIV>
				</DIV>
			</DIV><DIV CLASS='content' STYLE='background: #F7F7F7; text-align: center; padding: 20px;'><DIV ID='errorList'></DIV><H1>Mesh and 3D object downloads<BR/>
        <SPAN STYLE='font-size: xx-small;'>Please also consider <A HREF='https://trekmeshes.eu/upload'>uploading</A> your Star Trek 3D work</SPAN></H1><P>Use the checkboxes below to filter your desired results. <A HREF='https://trekmeshes.eu/download/all'>Clicking here</A> will show all available meshes.</P>
        <FORM METHOD='POST' ACTION='https://trekmeshes.eu/download' > <INPUT TYPE='HIDDEN' NAME='search[CHECKBOX]' VALUE='PRESENT' />
        <TABLE CLASS='centered'><TR><TD>
        <TABLE CLASS='defaultTable centered paddedLR'
					 >
					 	<THEAD><TR>
						 	<TH STYLE='width:1px;'><INPUT TYPE='CHECKBOX' ONCLICK='toggleformats(this.checked);' /></TH><TH>Format</TH><TH>Description</TH>		</TR></THEAD>
						<TBODY><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats1]' CHECKED CLASS='boxArrayformats' ID='formats1'  ></TD><TD ONCLICK='toggleSingleformats("formats1");' >3DS</TD><TD ONCLICK='toggleSingleformats("formats1");' >3D Studio Legacy (3DS or PRJ file)</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats2]' CHECKED CLASS='boxArrayformats' ID='formats2'  ></TD><TD ONCLICK='toggleSingleformats("formats2");' >MAX</TD><TD ONCLICK='toggleSingleformats("formats2");' ><A HREF='https://www.autodesk.com/products/3ds-max' ONCLICK='return confirm("This link is not part of Trekmeshes.eu, and Trekmeshes is not affiliated with, nor responsible for, its content. Would you like to continue?");' TARGET='_BLANK'>3D Studio MAX</A></TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats3]' CHECKED CLASS='boxArrayformats' ID='formats3'  ></TD><TD ONCLICK='toggleSingleformats("formats3");' >COB</TD><TD ONCLICK='toggleSingleformats("formats3");' ><A HREF='https://united3dartists.com/' ONCLICK='return confirm("This link is not part of Trekmeshes.eu, and Trekmeshes is not affiliated with, nor responsible for, its content. Would you like to continue?");' TARGET='_BLANK'>Caligari trueSpace (abandonware, free)</A></TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats4]' CHECKED CLASS='boxArrayformats' ID='formats4'  ></TD><TD ONCLICK='toggleSingleformats("formats4");' >LWO</TD><TD ONCLICK='toggleSingleformats("formats4");' ><A HREF='https://www.lightwave3d.com/' ONCLICK='return confirm("This link is not part of Trekmeshes.eu, and Trekmeshes is not affiliated with, nor responsible for, its content. Would you like to continue?");' TARGET='_BLANK'>Lightwave 3D</A></TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats5]' CHECKED CLASS='boxArrayformats' ID='formats5'  ></TD><TD ONCLICK='toggleSingleformats("formats5");' >blend</TD><TD ONCLICK='toggleSingleformats("formats5");' ><A HREF='https://www.blender.org/' ONCLICK='return confirm("This link is not part of Trekmeshes.eu, and Trekmeshes is not affiliated with, nor responsible for, its content. Would you like to continue?");' TARGET='_BLANK'>Blender (free)</A></TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats6]' CHECKED CLASS='boxArrayformats' ID='formats6'  ></TD><TD ONCLICK='toggleSingleformats("formats6");' >PSR</TD><TD ONCLICK='toggleSingleformats("formats6");' ><A HREF='https://www.posersoftware.com/downloads' ONCLICK='return confirm("This link is not part of Trekmeshes.eu, and Trekmeshes is not affiliated with, nor responsible for, its content. Would you like to continue?");' TARGET='_BLANK'>Poser</A></TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats7]' CHECKED CLASS='boxArrayformats' ID='formats7'  ></TD><TD ONCLICK='toggleSingleformats("formats7");' >OBJ</TD><TD ONCLICK='toggleSingleformats("formats7");' >Wavefront OBJ</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats8]' CHECKED CLASS='boxArrayformats' ID='formats8'  ></TD><TD ONCLICK='toggleSingleformats("formats8");' >C4D</TD><TD ONCLICK='toggleSingleformats("formats8");' ><A HREF='https://www.maxon.net/en/cinema-4d' ONCLICK='return confirm("This link is not part of Trekmeshes.eu, and Trekmeshes is not affiliated with, nor responsible for, its content. Would you like to continue?");' TARGET='_BLANK'>Maxon Cinema 4D</A></TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[formats11]' CHECKED CLASS='boxArrayformats' ID='formats11'  ></TD><TD ONCLICK='toggleSingleformats("formats11");' >DAE</TD><TD ONCLICK='toggleSingleformats("formats11");' >Digital Asset Exchange format</TD></TR></TBODY></TABLE>
				<SCRIPT>
					function toggleformats(value) {
						var checkboxes = document.getElementsByClassName('boxArrayformats');
						for (var i = 0; i < checkboxes.length; i++) {
							checkboxes[i].checked = value;
						}
					}
					function toggleSingleformats(ID) {
						if (document.getElementById(ID).checked) {
							document.getElementById(ID).checked = false;
						} else {
							document.getElementById(ID).checked = true;
						}
					}
				</SCRIPT>
        <TABLE CLASS='defaultTable centered paddedLR'
					 >
					 	<THEAD><TR>
						 	<TH STYLE='width:1px;'><INPUT TYPE='CHECKBOX' ONCLICK='toggleraces(this.checked);' /></TH><TH>Associated race</TH>		</TR></THEAD>
						<TBODY><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races1]' CHECKED CLASS='boxArrayraces' ID='races1'  ></TD><TD ONCLICK='toggleSingleraces("races1");' >Starfleet (Federation)</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races2]' CHECKED CLASS='boxArrayraces' ID='races2'  ></TD><TD ONCLICK='toggleSingleraces("races2");' >Klingon</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races3]' CHECKED CLASS='boxArrayraces' ID='races3'  ></TD><TD ONCLICK='toggleSingleraces("races3");' >Romulan</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races4]' CHECKED CLASS='boxArrayraces' ID='races4'  ></TD><TD ONCLICK='toggleSingleraces("races4");' >Borg</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races5]' CHECKED CLASS='boxArrayraces' ID='races5'  ></TD><TD ONCLICK='toggleSingleraces("races5");' >Cardassian</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races6]' CHECKED CLASS='boxArrayraces' ID='races6'  ></TD><TD ONCLICK='toggleSingleraces("races6");' >Jem&amp;hadar</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races7]' CHECKED CLASS='boxArrayraces' ID='races7'  ></TD><TD ONCLICK='toggleSingleraces("races7");' >Other</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[races8]' CHECKED CLASS='boxArrayraces' ID='races8'  ></TD><TD ONCLICK='toggleSingleraces("races8");' >Non-specific</TD></TR></TBODY></TABLE>
				<SCRIPT>
					function toggleraces(value) {
						var checkboxes = document.getElementsByClassName('boxArrayraces');
						for (var i = 0; i < checkboxes.length; i++) {
							checkboxes[i].checked = value;
						}
					}
					function toggleSingleraces(ID) {
						if (document.getElementById(ID).checked) {
							document.getElementById(ID).checked = false;
						} else {
							document.getElementById(ID).checked = true;
						}
					}
				</SCRIPT>
        <TABLE CLASS='defaultTable centered paddedLR'
					 >
					 	<THEAD><TR>
						 	<TH STYLE='width:1px;'><INPUT TYPE='CHECKBOX' ONCLICK='toggletypes(this.checked);' /></TH><TH>Type of mesh</TH>		</TR></THEAD>
						<TBODY><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[types1]' CHECKED CLASS='boxArraytypes' ID='types1'  ></TD><TD ONCLICK='toggleSingletypes("types1");' >Starships</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[types2]' CHECKED CLASS='boxArraytypes' ID='types2'  ></TD><TD ONCLICK='toggleSingletypes("types2");' >Stations and Starbases</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[types3]' CHECKED CLASS='boxArraytypes' ID='types3'  ></TD><TD ONCLICK='toggleSingletypes("types3");' >Shuttlecraft and small vessels</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[types4]' CHECKED CLASS='boxArraytypes' ID='types4'  ></TD><TD ONCLICK='toggleSingletypes("types4");' >Interiors</TD></TR><TR>
							<TD>
							<INPUT TYPE='CHECKBOX' NAME='search[types5]' CHECKED CLASS='boxArraytypes' ID='types5'  ></TD><TD ONCLICK='toggleSingletypes("types5");' >Other (items, furnishing, ...)</TD></TR></TBODY></TABLE>
				<SCRIPT>
					function toggletypes(value) {
						var checkboxes = document.getElementsByClassName('boxArraytypes');
						for (var i = 0; i < checkboxes.length; i++) {
							checkboxes[i].checked = value;
						}
					}
					function toggleSingletypes(ID) {
						if (document.getElementById(ID).checked) {
							document.getElementById(ID).checked = false;
						} else {
							document.getElementById(ID).checked = true;
						}
					}
				</SCRIPT>
        <TABLE CLASS='defaultTable'><TR><TD STYLE='width: 1px;'><INPUT TYPE='CHECKBOX' NAME='search[canon]'  ></TD><TD>Display only meshes flagged as canon</TD></TR></TABLE>
        <TABLE CLASS='defaultTable rlAlign'>
            <TR><TD>Description, name or author must contain text:</TD><TD><INPUT TYPE='TEXT' NAME='search[freetext]' VALUE='' MINLENGTH='1'  /></TD></TR>
            <TR><TD>List only meshes uploaded after:</TD><TD><INPUT TYPE='DATE' NAME='search[date]' VALUE=''    /></TD></TR>
        </TABLE><BR/>
        <INPUT TYPE='SUBMIT' VALUE='Display meshes'  />        
        </TD></TR></TABLE>
        </FORM><P STYLE='text-align: right; font-size: x-small;'>Trekmeshes.eu, <A STYLE='font-size: xx-small;' HREF='https://trekmeshes.eu/download/all'>Overview of all 3D meshes</A>, <A STYLE='font-size: xx-small;' HREF='https://trekmeshes.eu/privacy'>Privacy and cookie policy</A></P></DIV></div></body></html>